# Ozon Seller API credentials
OZON_CLIENT_ID=your_client_id_here
OZON_API_KEY=your_api_key_here

# Output file
OUTPUT_FILE=ozon_products_api.xlsx

# Visibility filter: ALL, VISIBLE, INVISIBLE, EMPTY_STOCK, NOT_MODERATED, MODERATED,
# FAILED_MODERATION, READY_TO_SUPPLY, IN_SALE, REMOVED_FROM_SALE, BANNED, OVERPRICED,
# INACTIVE, EMPTY_NAME, EMPTY_DESCRIPTION, EMPTY_CATEGORY, EMPTY_BARCODE,
# EMPTY_WEIGHT, EMPTY_DIMENSIONS, EMPTY_PHOTOS
OZON_VISIBILITY=ALL

# Max products to collect (0 = all)
MAX_PRODUCTS=0

# Batch size for API requests (max 1000)
BATCH_SIZE=500

# Parallel workers for fetching descriptions
DESCRIPTION_WORKERS=20
